<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TokenBar.App.ViewModels"
        x:Class="TokenBar.App.MiniWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="430"
        Height="150"
        MinWidth="430"
        MinHeight="150"
        MaxWidth="430"
        MaxHeight="150"
        Title="TokenBar"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        TransparencyLevelHint="AcrylicBlur"
        WindowDecorations="None">
    <Window.Styles>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#B7B9BD" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="#F1F3F4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="Foreground" Value="#F1F3F4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.close">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#DADCE0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ProgressBar.compact">
            <Setter Property="Background" Value="#3A3B3D" />
            <Setter Property="Foreground" Value="#5E8CFF" />
            <Setter Property="Height" Value="5" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
    </Window.Styles>

    <Border Background="#202124"
            BorderBrush="#3A3B3D"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12"
            PointerPressed="WindowPointerPressed">
        <Grid RowDefinitions="Auto,*"
              ColumnDefinitions="Auto,*,Auto">
            <Border Width="38"
                    Height="38"
                    Background="#111827"
                    CornerRadius="6"
                    VerticalAlignment="Top"
                    Margin="0,0,12,0">
                <Grid>
                    <Ellipse Width="18"
                             Height="18"
                             Stroke="#22D3EE"
                             StrokeThickness="2" />
                    <Ellipse Width="5"
                             Height="5"
                             Fill="#22D3EE" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Classes="title"
                           Text="TokenBar" />
                <TextBlock Classes="muted"
                           Text="{Binding LastUpdated}" />
            </StackPanel>

            <Button Grid.Column="2"
                    Classes="close"
                    Content="x"
                    Click="HideClicked" />

            <ItemsControl Grid.Row="1"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Margin="0,10,0,0"
                          ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProviderRowViewModel">
                        <Grid ColumnDefinitions="98,*,78"
                              RowDefinitions="Auto,Auto"
                              Margin="0,0,0,7">
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Classes="title"
                                       Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                            <ProgressBar Grid.Row="0"
                                         Grid.Column="1"
                                         Classes="compact"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding PrimaryPercentUsed}"
                                         Margin="8,6,8,0"
                                         IsVisible="{Binding HasPrimaryPercent}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Classes="value"
                                       Text="{Binding PrimaryValue}"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Classes="muted"
                                       Text="{Binding PrimaryReset}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="8,1,0,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
