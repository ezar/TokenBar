<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TokenBar.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="420"
        d:DesignHeight="320"
        x:Class="TokenBar.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="520"
        Height="440"
        MinWidth="460"
        MinHeight="360"
        Title="TokenBar"
        Background="#F6F8FA"
        WindowStartupLocation="CenterScreen">
    <Window.Styles>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#57606A" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.metric">
            <Setter Property="Foreground" Value="#24292F" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.provider">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="Button.refresh">
            <Setter Property="Background" Value="#24292F" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,14">
            <Grid ColumnDefinitions="*,Auto"
                  RowDefinitions="Auto,Auto,Auto">
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Spacing="2">
                    <TextBlock Text="TokenBar"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#24292F" />
                    <TextBlock Classes="muted"
                               Text="Uso de APIs y cuotas configuradas" />
                </StackPanel>
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Classes="refresh"
                        Content="Refresh"
                        Click="RefreshClicked" />
                <ProgressBar Grid.Row="1"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             Height="3"
                             Margin="0,14,0,10"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsRefreshing}" />
                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      ColumnDefinitions="*,*">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="muted"
                                   Text="Last updated" />
                        <TextBlock Classes="metric"
                                   Text="{Binding LastUpdated}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="2">
                        <TextBlock Classes="muted"
                                   Text="{Binding RefreshIntervalText}" />
                        <TextBlock Classes="metric"
                                   Text="{Binding NextRefreshIn}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProviderRowViewModel">
                        <Border Classes="provider">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Row="0"
                                        Grid.Column="0"
                                        Width="4"
                                        Height="38"
                                        Background="{Binding BrandColor}"
                                        CornerRadius="2"
                                        Margin="0,0,12,0" />
                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#24292F" />
                                    <TextBlock Classes="muted"
                                               Text="{Binding Source}" />
                                </StackPanel>
                                <Border Grid.Row="0"
                                        Grid.Column="2"
                                        BorderBrush="{Binding StatusColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,3"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusColor}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Grid Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      ColumnDefinitions="*,*"
                                      Margin="0,12,0,0">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="muted"
                                                   Text="{Binding PrimaryLabel}" />
                                        <TextBlock Classes="metric"
                                                   Text="{Binding PrimaryValue}" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding PrimaryPercentUsed}"
                                                     Height="6"
                                                     Margin="0,4,14,0"
                                                     IsVisible="{Binding HasPrimaryPercent}" />
                                        <TextBlock Classes="muted"
                                                   Text="{Binding PrimaryReset}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Spacing="2"
                                                IsVisible="{Binding HasSecondary}">
                                        <TextBlock Classes="muted"
                                                   Text="{Binding SecondaryLabel}" />
                                        <TextBlock Classes="metric"
                                                   Text="{Binding SecondaryValue}" />
                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding SecondaryPercentUsed}"
                                                     Height="6"
                                                     Margin="0,4,0,0"
                                                     IsVisible="{Binding HasSecondaryPercent}" />
                                        <TextBlock Classes="muted"
                                                   Text="{Binding SecondaryReset}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Classes="muted"
                                           Text="{Binding Message}"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding HasMessage}"
                                           Margin="0,10,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
